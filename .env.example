# Service
SERVICE_NAME=LLM Gateway
SERVICE_VERSION=1.0.0
SERVICE_DESCRIPTION=OpenAI-compatible gateway for vLLM backends

# Auth
API_KEY=sk-your-secret-key-change-me

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=4
LOG_LEVEL=info

# CORS (comma-separated, * for all)
ALLOWED_ORIGINS=*

# Proxy tuning
REQUEST_TIMEOUT=300
MAX_CONNECTIONS=500

# Data paths (auto-created on startup)
DATA_DIR=data
MODELS_PATH=data/models.json
STATS_PATH=data/stats.json